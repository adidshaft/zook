NODE_ENV=development
APP_ENV="local"
ENV_PROFILE="local"
API_MODE="backend"
DATABASE_URL="postgresql://zook:zook@localhost:5432/zook?schema=public"
SESSION_SECRET="replace-me-with-a-long-random-secret"
OTP_FIXED_CODE_DEV="000000"
ALLOW_FIXED_OTP_IN_STAGING="false"
ALLOW_DEV_OTP_RESPONSE="false"
ALLOW_MOCK_PAYMENT_COMPLETION="false"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
MOBILE_API_BASE_URL="http://127.0.0.1:3000/api"
EXPO_PUBLIC_APP_ENV="local"
EXPO_PUBLIC_API_MODE="backend"
EXPO_PUBLIC_API_BASE_URL="http://127.0.0.1:3000/api"
EXPO_PUBLIC_WEB_URL="http://localhost:3000"
ZOOK_QR_SECRET="replace-me-with-a-long-random-qr-secret"
STORAGE_LOCAL_DIR="./.local/uploads"
STORAGE_URL_SIGNING_SECRET=""
FILE_UPLOADS_ENABLED="true"
SEED_DEMO_USERS_ENABLED="true"
MAINTENANCE_MOCK_MODE="false"
ALLOW_MOCK_EMAIL_OTP_LOGS="false"
EMAIL_FROM="Zook <noreply@zook.local>"
SMTP_FROM="Zook <noreply@zook.local>"
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_IMAGE_MODEL="gpt-image-1"
OPENAI_TIMEOUT_MS="20000"
RAZORPAY_CHECKOUT_BASE_URL=""
RAZORPAY_MODE="test"
PUSH_ENVIRONMENT="development"
APP_SCHEME="zook"

# Provider selection. Mocks are the low-cost local default. Use disabled to surface a controlled unavailable state.
PAYMENT_PROVIDER="mock"
MAP_PROVIDER="mock"
AI_PROVIDER="mock"
EMAIL_PROVIDER="mock"
SMS_PROVIDER="mock"
PUSH_PROVIDER="mock"
STORAGE_PROVIDER="local"

# AI
OPENAI_API_KEY=""

# Email
RESEND_API_KEY=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# Maps
GOOGLE_MAPS_API_KEY=""

# Future hosted payment providers. Leave unset for local development.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
CASHFREE_APP_ID=""
CASHFREE_SECRET=""
PHONEPE_MERCHANT_ID=""
PHONEPE_SALT_KEY=""
PAYU_KEY=""
PAYU_SALT=""

# Local, disabled, or S3/R2-compatible object storage.
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_REGION=""
R2_ACCOUNT_ID=""
S3_PUBLIC_BASE_URL=""

# Push scaffolding
EXPO_ACCESS_TOKEN=""
EXPO_PROJECT_ID=""

# Optional error reporting
ERROR_REPORTER="mock"
SENTRY_DSN=""
SENTRY_ENVIRONMENT=""
