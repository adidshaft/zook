NODE_ENV=development
DATABASE_URL="postgresql://zook:zook@localhost:5432/zook?schema=public"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
ZOOK_SESSION_SECRET="replace-me-with-a-long-random-secret"
ZOOK_QR_SECRET="replace-me-with-a-long-random-qr-secret"
ZOOK_MOCK_OTP="000000"

# Provider selection. Mocks are the local default.
PAYMENT_PROVIDER="mock"
MAP_PROVIDER="mock"
AI_PROVIDER="mock"
EMAIL_PROVIDER="mock"
SMS_PROVIDER="mock"
PUSH_PROVIDER="mock"
STORAGE_PROVIDER="local"

# Future real providers. Leave unset for local development.
OPENAI_API_KEY=""
GOOGLE_MAPS_API_KEY=""
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
CASHFREE_APP_ID=""
CASHFREE_SECRET=""
PHONEPE_MERCHANT_ID=""
PHONEPE_SALT_KEY=""
PAYU_KEY=""
PAYU_SALT=""
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
