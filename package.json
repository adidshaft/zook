{
  "name": "zook",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.16.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @zook/web dev",
    "dev:mobile": "pnpm --filter @zook/mobile start",
    "build": "turbo build",
    "preflight": "tsx scripts/preflight.ts",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:unit": "vitest run -c vitest.config.ts",
    "test:web": "playwright test",
    "test:services": "vitest run -c vitest.config.ts packages/core/src/__tests__/**/*.{test,spec}.ts apps/web/src/**/*.{test,spec}.ts",
    "test:acceptance": "tsx scripts/test-acceptance.ts",
    "db:generate": "pnpm --filter @zook/db db:generate",
    "db:push": "pnpm --filter @zook/db db:push",
    "db:migrate": "pnpm --filter @zook/db db:migrate",
    "db:seed": "pnpm --filter @zook/db db:seed",
    "db:reset": "tsx scripts/seed-reset.ts",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.50.1",
    "@types/node": "^22.10.7",
    "dotenv": "^16.6.1",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsx": "^4.20.6",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.0.5"
  }
}
