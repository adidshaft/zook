{
  "name": "zook",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.16.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @zook/web dev",
    "dev:mobile": "pnpm --filter @zook/mobile start",
    "build": "turbo build",
    "preflight": "tsx scripts/preflight.ts",
    "env:check": "tsx scripts/check-release-env.ts",
    "release:preflight": "tsx scripts/release-preflight.ts",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:unit": "vitest run -c vitest.config.ts",
    "test:web": "playwright test",
    "test:services": "vitest run -c vitest.config.ts packages/core/src/__tests__/**/*.{test,spec}.ts apps/web/src/**/*.{test,spec}.ts",
    "test:db:prepare": "tsx scripts/test-db-bootstrap.ts",
    "test:acceptance": "tsx scripts/test-acceptance.ts",
    "test:acceptance:db": "tsx scripts/test-acceptance.ts --require-db",
    "test:acceptance:db:headed": "tsx scripts/test-acceptance.ts --require-db --headed",
    "test:acceptance:db:debug": "tsx scripts/test-acceptance.ts --require-db --debug",
    "check:dashboard-copy": "tsx scripts/check-dashboard-copy.ts",
    "db:local:up": "docker compose up -d postgres",
    "db:local:setup": "tsx scripts/db-local-setup.ts",
    "db:baseline": "tsx scripts/prisma-db.ts migrate resolve --applied 20260503000000_initial_baseline --schema prisma/schema.prisma",
    "db:generate": "tsx scripts/prisma-db.ts generate --schema prisma/schema.prisma",
    "db:push": "tsx scripts/prisma-db.ts db push --schema prisma/schema.prisma",
    "db:migrate": "tsx scripts/prisma-db.ts migrate dev --schema prisma/schema.prisma",
    "db:deploy": "tsx scripts/prisma-db.ts migrate deploy --schema prisma/schema.prisma",
    "db:studio": "tsx scripts/prisma-db.ts studio --schema prisma/schema.prisma",
    "db:seed": "pnpm --filter @zook/db db:seed",
    "icons:generate": "node scripts/generate-zook-icons.mjs",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "seed:pilot": "tsx scripts/seed-pilot.ts",
    "db:reset": "tsx scripts/seed-reset.ts",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.50.1",
    "@types/node": "^22.10.7",
    "dotenv": "^16.6.1",
    "eslint": "^9.18.0",
    "metro-runtime": "^0.83.3",
    "prettier": "^3.4.2",
    "tsx": "^4.20.6",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.0.5"
  }
}
