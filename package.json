{
  "name": "zook",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.16.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @zook/web dev",
    "dev:mobile": "pnpm --filter @zook/mobile start",
    "build": "pnpm check:i18n && turbo build",
    "preflight": "tsx scripts/preflight.ts && pnpm check:i18n",
    "env:check": "tsx scripts/check-release-env.ts",
    "release:preflight": "tsx scripts/release-preflight.ts && pnpm check:cleanup-audit",
    "mobile:release:check": "tsx scripts/check-mobile-release-readiness.ts",
    "screenshots:check": "tsx scripts/check-screenshot-variance.ts",
    "check:cleanup-audit": "tsx scripts/check-mobile-ui-cleanup-audit.ts",
    "check:launch-gates": "tsx scripts/check-launch-gates.ts",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint && pnpm check:i18n && pnpm check:launch-gates && pnpm check:cleanup-audit",
    "test": "turbo test",
    "test:unit": "vitest run -c vitest.config.ts",
    "test:web": "node scripts/run-web-tests.mjs",
    "test:web:actions": "RUN_DB_WEB_TESTS=1 PLAYWRIGHT_RATE_LIMIT_PROVIDER=memory AI_FEATURES_ENABLED=true AI_PROVIDER=mock NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=test-google-web.apps.googleusercontent.com GOOGLE_WEB_CLIENT_ID=test-google-web.apps.googleusercontent.com NEXT_PUBLIC_APPLE_CLIENT_ID=com.zook.app APPLE_CLIENT_ID=com.zook.app APPLE_SERVICE_ID=com.zook.web APPLE_BUNDLE_ID=com.zook.app playwright test apps/web/tests/*-actions.spec.ts",
    "test:integration": "RUN_DB_WEB_TESTS=1 PLAYWRIGHT_RATE_LIMIT_PROVIDER=memory AI_FEATURES_ENABLED=true AI_PROVIDER=mock PAYMENT_PROVIDER=mock ALLOW_MOCK_PAYMENT_COMPLETION=true playwright test apps/web/tests/integration-*.spec.ts",
    "test:mobile:maestro": "pnpm test:mobile:maestro:ios",
    "test:mobile:maestro:ios": "pnpm seed:pilot && MAESTRO_CLI_NO_ANALYTICS=1 ~/.maestro/bin/maestro --platform ios --udid ${MAESTRO_IOS_UDID:-16E85351-C822-4E5D-8C0F-15A50B8BFA5C} test apps/mobile/.maestro/flows/*.yaml",
    "test:mobile:maestro:android": "pnpm seed:pilot && adb reverse tcp:3000 tcp:3000 && adb reverse tcp:8081 tcp:8081 && MAESTRO_CLI_NO_ANALYTICS=1 ~/.maestro/bin/maestro --platform android test apps/mobile/.maestro/flows/*.yaml",
    "test:e2e": "pnpm test:web && pnpm test:web:actions && pnpm test:mobile:maestro:ios && pnpm test:mobile:maestro:android && pnpm test:integration",
    "test:services": "vitest run -c vitest.config.ts packages/core/src/__tests__ apps/web/src --passWithNoTests",
    "test:db:prepare": "tsx scripts/test-db-bootstrap.ts",
    "test:acceptance": "tsx scripts/test-acceptance.ts",
    "test:acceptance:db": "tsx scripts/test-acceptance.ts --require-db",
    "test:acceptance:db:headed": "tsx scripts/test-acceptance.ts --require-db --headed",
    "test:acceptance:db:debug": "tsx scripts/test-acceptance.ts --require-db --debug",
    "test:load": "k6 run scripts/load/pilot-smoke.js",
    "cert:razorpay-webhook": "tsx scripts/razorpay-webhook-cert.ts",
    "smoke:resend": "tsx scripts/resend-smoke.ts",
    "analyze:web": "pnpm --filter @zook/web analyze",
    "check:dashboard-copy": "tsx scripts/check-dashboard-copy.ts",
    "check:i18n": "tsx scripts/check-dashboard-copy.ts && tsx scripts/audit-i18n.ts",
    "db:local:up": "docker compose up -d postgres",
    "db:local:setup": "tsx scripts/db-local-setup.ts",
    "db:baseline": "tsx scripts/prisma-db.ts migrate resolve --applied 20260503000000_initial_baseline --schema prisma/schema.prisma",
    "db:generate": "tsx scripts/prisma-db.ts generate --schema prisma/schema.prisma",
    "db:push": "tsx scripts/prisma-db.ts db push --schema prisma/schema.prisma",
    "db:migrate": "tsx scripts/prisma-db.ts migrate dev --schema prisma/schema.prisma",
    "db:deploy": "tsx scripts/prisma-db.ts migrate deploy --schema prisma/schema.prisma",
    "db:studio": "tsx scripts/prisma-db.ts studio --schema prisma/schema.prisma",
    "db:seed": "pnpm --filter @zook/db db:seed",
    "db:fk-inventory": "tsx scripts/generate-fk-inventory.ts",
    "db:a1.5:sql": "tsx scripts/a1.5-single-active-subscription-sql.ts",
    "db:a1.6:sql": "tsx scripts/a1.6-attendance-per-day-sql.ts",
    "db:a1.7:sql": "tsx scripts/a1.7-visit-deduction-sql.ts",
    "db:a3.1:sql": "tsx scripts/a3.1-durable-queue-sql.ts",
    "db:a3.2:sql": "tsx scripts/a3.2-broadcast-fanout-sql.ts",
    "db:a3.3:sql": "tsx scripts/a3.3-async-push-delivery-sql.ts",
    "db:a3.4:sql": "tsx scripts/a3.4-renewal-reminder-queue-sql.ts",
    "db:a3.6:sql": "tsx scripts/a3.6-idempotency-expiry-sql.ts",
    "db:b1:sql": "tsx scripts/b1-rbac-multi-branch-role-sql.ts",
    "db:b2:sql": "tsx scripts/b2-status-enum-rollout-sql.ts",
    "db:b3:sql": "tsx scripts/b3-invoice-column-collapse-sql.ts",
    "db:b4:sql": "tsx scripts/b4-branch-scope-model-sql.ts",
    "db:b5:sql": "tsx scripts/b5-uniqueness-gap-sql.ts",
    "db:b6:sql": "tsx scripts/b6-retention-scale-sql.ts",
    "icons:generate": "node scripts/generate-zook-icons.mjs",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "seed:pilot": "tsx scripts/seed-pilot.ts",
    "db:reset": "tsx scripts/seed-reset.ts",
    "account-deletion:purge": "tsx scripts/account-deletion-purge.ts",
    "format": "prettier --write ."
  },
  "pnpm": {
    "overrides": {
      "fast-xml-builder": ">=1.1.7",
      "shell-quote": "1.8.4",
      "undici": "6.27.0",
      "vite@<=6.4.2": "6.4.3",
      "ws@>=6.0.0 <6.2.4": "6.2.4",
      "ws@>=7.0.0 <7.5.11": "7.5.11",
      "ws@>=8.0.0 <8.21.0": "8.21.0"
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.50.1",
    "@types/node": "^22.10.7",
    "dotenv": "^16.6.1",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "metro-runtime": "^0.83.3",
    "prettier": "^3.4.2",
    "tsx": "^4.20.6",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.2.6"
  }
}
