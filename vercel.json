{
  "buildCommand": "pnpm db:generate && npx turbo run build --filter=@zook/web...",
  "outputDirectory": "apps/web/.next",
  "installCommand": "pnpm install",
  "crons": [
    {
      "path": "/api/cron/renewal-reminders",
      "schedule": "30 1 * * *"
    },
    {
      "path": "/api/cron/account-deletion-purge",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/refund-reconcile",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/trainer-payouts-draft",
      "schedule": "1 0 1 * *"
    },
    {
      "path": "/api/cron/rewards-settle",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/send-scheduled-notifications",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/subscription-expiry",
      "schedule": "0 * * * *"
    }
  ]
}
