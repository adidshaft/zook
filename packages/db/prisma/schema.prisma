model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerifiedAt   DateTime?
  name              String
  slug              String?   @unique @db.VarChar(32)
  phone             String?
  phoneVerifiedAt   DateTime?
  dateOfBirth       DateTime?
  profilePhotoUrl   String?
  gender            String?
  fitnessGoal       String?
  emergencyContact  Json?
  isMinor           Boolean   @default(false)
  guardianPending   Boolean   @default(false)
  isPlatformAdmin   Boolean   @default(false)
  marketingOptIn    Boolean   @default(true)
  aiConsent         Boolean   @default(false)
  preferredLocale   String    @default("en")
  weeklyWorkoutGoal Int       @default(5)
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([email])
  @@index([phone])
  @@index([isPlatformAdmin])
}

model UserSession {
  id                    String    @id @default(cuid())
  userId                String
  originalUserId        String?
  impersonationSessionId String?
  tokenHash             String    @unique
  refreshTokenHash      String?   @unique
  userAgent             String?
  ipAddress             String?
  deviceLabel           String?
  deviceFingerprintHash String?
  newDeviceNotifiedAt   DateTime?
  lastSeenAt            DateTime?
  revokedAt             DateTime?
  expiresAt             DateTime
  refreshExpiresAt      DateTime?
  createdAt             DateTime  @default(now())

  @@index([userId])
  @@index([impersonationSessionId])
  @@index([originalUserId])
  @@index([userId, deviceFingerprintHash])
  @@index([expiresAt])
  @@index([refreshExpiresAt])
}

model AuthIdentity {
  id             String               @id @default(cuid())
  userId         String
  provider       AuthIdentityProvider
  providerUserId String
  email          String?
  emailVerified  Boolean              @default(false)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([email])
}

model OtpChallenge {
  id             String    @id @default(cuid())
  email          String
  identifier     String
  channel        String    @default("email")
  phone          String?
  codeHash       String
  purpose        String    @default("login")
  attempts       Int       @default(0)
  maxAttempts    Int       @default(5)
  resendCount    Int       @default(0)
  ipFailureCount Int       @default(0)
  lockedUntil    DateTime?
  ipAddress      String?
  consumedAt     DateTime?
  expiresAt      DateTime
  createdAt      DateTime  @default(now())

  @@index([email, purpose])
  @@index([identifier, purpose])
  @@index([phone, purpose])
  @@index([ipAddress, purpose])
  @@index([lockedUntil])
  @@index([expiresAt])
}

model RequestIdempotency {
  id          String   @id @default(cuid())
  userId      String?
  operation   String
  requestHash String
  resultHash  String
  status      Int
  body        Json
  createdAt   DateTime @default(now())

  @@unique([userId, operation, requestHash])
  @@index([createdAt])
}

model FileAsset {
  id              String    @id @default(cuid())
  orgId           String?
  ownerUserId     String?
  originalName    String?
  storageKey      String
  url             String
  mimeType        String
  sizeBytes       Int
  purpose         String
  category        String?
  visibility      String?   @default("private")
  storageProvider String?   @default("local")
  checksum        String?
  metadata        Json?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())

  @@index([orgId])
  @@index([ownerUserId])
}

model AuditLog {
  id          String         @id @default(cuid())
  orgId       String?
  actorUserId String?
  requestId   String?
  action      String
  entityType  String
  entityId    String?
  ipAddress   String?
  userAgent   String?
  before      Json?
  after       Json?
  riskLevel   AuditRiskLevel @default(LOW)
  metadata    Json?
  createdAt   DateTime       @default(now())

  @@index([orgId, createdAt])
  @@index([createdAt, orgId])
  @@index([actorUserId, createdAt])
  @@index([riskLevel, createdAt])
}

model Organization {
  id                    String             @id @default(cuid())
  name                  String
  username              String             @unique
  logoUrl               String?
  coverImageUrl         String?
  contactPhone          String?
  contactEmail          String?
  address               String
  city                  String
  state                 String
  pincode               String
  country               String             @default("India")
  latitude              Decimal?           @db.Decimal(10, 7)
  longitude             Decimal?           @db.Decimal(10, 7)
  googlePlaceId         String?
  originalGoogleMapsUrl String?
  locationSource        LocationSource     @default(MANUAL)
  operatingHours        Json?
  amenities             Json?
  visibility            GymVisibility      @default(PUBLIC)
  joinMode              GymJoinMode        @default(OPEN_JOIN)
  status                OrganizationStatus @default(TRIAL_ACTIVE)
  trialStartAt          DateTime           @default(now())
  trialEndAt            DateTime
  gstNumber             String?
  legalName             String?
  attendanceMode        AttendanceMode     @default(EXCEPTION_APPROVAL)
  multiEntryConsumes    Boolean            @default(false)
  allowSelfServePause   Boolean            @default(true)
  settings              Json?
  createdByUserId       String
  deletedAt             DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([city])
  @@index([status])
  @@index([visibility])
  @@index([latitude, longitude])
}

model OrganizationUsernameHistory {
  id          String   @id @default(cuid())
  orgId       String
  oldUsername String   @unique
  newUsername String
  changedById String
  createdAt   DateTime @default(now())

  @@index([orgId])
}

model Branch {
  id             String         @id @default(cuid())
  orgId          String
  name           String
  address        String
  city           String
  state          String
  pincode        String
  latitude       Decimal?       @db.Decimal(10, 7)
  longitude      Decimal?       @db.Decimal(10, 7)
  googleMapsUrl  String?
  locationSource LocationSource @default(MANUAL)
  contactPhone   String?
  contactEmail   String?
  operatingHours Json?
  amenities      String[]       @default([])
  managerId      String?
  logoAssetId    String?
  coverAssetId   String?
  whatsappNumber String?
  qrMode         String         @default("ROLLING")
  staticQrExpiryDays Int       @default(30)
  isDefault      Boolean        @default(false)
  active         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([orgId, name])
  @@index([orgId])
  @@index([orgId, managerId])
}

model OrganizationUser {
  id        String    @id @default(cuid())
  orgId     String
  userId    String
  status    String    @default("active")
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([orgId, userId])
  @@index([userId])
}

model OrganizationRoleAssignment {
  id           String   @id @default(cuid())
  orgId        String
  userId       String
  role         Role
  branchId     String?
  assignedById String?
  createdAt    DateTime @default(now())

  @@unique([orgId, userId])
  @@unique([orgId, userId, role])
  @@index([orgId, role])
  @@index([orgId, branchId])
  @@index([userId])
}

model OrganizationRolePermission {
  id                 String     @id @default(cuid())
  orgId              String
  role               Role
  permission         Permission
  enabled            Boolean    @default(true)
  overriddenByUserId String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@unique([orgId, role, permission])
  @@index([orgId])
}

model StaffInvitation {
  id           String    @id @default(cuid())
  orgId        String
  email        String
  role         Role
  branchId     String?
  token        String    @unique
  invitedById  String
  acceptedById String?
  acceptedAt   DateTime?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  @@index([orgId, email])
  @@index([orgId, branchId])
}

model SaaSSubscription {
  id                String             @id @default(cuid())
  orgId             String             @unique
  status            OrganizationStatus @default(TRIAL_ACTIVE)
  tier              SaaSTier           @default(FREE)
  billingCycle      SaaSBillingCycle   @default(MONTHLY)
  trialStartAt      DateTime
  trialEndAt        DateTime
  trialExtendedDays Int                @default(0)
  creditPaise       Int                @default(0)
  noteForPlatform   String?
  billingEmail      String?
  paymentSessionId  String?
  nextBillingAt     DateTime?
  nextRenewalAt     DateTime?
  priceLockedPaise  Int?
  cancelledAt       DateTime?
  cancelAtPeriodEnd Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([status])
}

model SaaSBillingMandate {
  id                String               @id @default(cuid())
  provider          String               @default("mock")
  providerMandateId String?
  providerPlanId    String?
  orgId             String               @unique
  createdByUserId   String
  status            PaymentMandateStatus @default(CREATED)
  amountPaise       Int
  currency          String               @default("INR")
  billingPeriod     String               @default("monthly")
  billingInterval   Int                  @default(1)
  totalCount        Int                  @default(120)
  paidCount         Int                  @default(0)
  checkoutUrl       String?
  currentStartAt    DateTime?
  currentEndAt      DateTime?
  nextChargeAt      DateTime?
  authenticatedAt   DateTime?
  activatedAt       DateTime?
  cancelledAt       DateTime?
  paymentSessionId  String?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([provider, providerMandateId])
  @@index([status])
  @@index([nextChargeAt])
}

model OrganizationSetting {
  id        String   @id @default(cuid())
  orgId     String   @unique
  keyValues Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformBroadcast {
  id              String                    @id @default(cuid())
  title           String
  body            String
  severity        PlatformBroadcastSeverity @default(INFO)
  targetOrgIds    String[]                  @default([])
  targetRoles     Role[]                    @default([])
  scheduledAt     DateTime?
  expiresAt       DateTime?
  publishedAt     DateTime?
  status          PlatformBroadcastStatus   @default(DRAFT)
  createdByUserId String
  createdAt       DateTime                  @default(now())

  @@index([status, scheduledAt])
  @@index([publishedAt])
}

model FeatureFlag {
  key             String   @id
  enabled         Boolean  @default(false)
  description     String?
  rolloutPercent  Int      @default(0)
  overrideOrgIds  String[] @default([])
  updatedAt       DateTime @updatedAt
  updatedByUserId String?
}

model ImpersonationSession {
  id                  String    @id @default(cuid())
  platformAdminUserId String
  targetUserId        String
  targetOrgId         String?
  reason              String
  startedAt           DateTime  @default(now())
  expiresAt           DateTime
  endedAt             DateTime?
  ipHash              String
  userAgentHash       String
  actionsCount        Int       @default(0)

  @@index([platformAdminUserId, startedAt])
  @@index([targetUserId, startedAt])
  @@index([targetOrgId, startedAt])
  @@index([endedAt])
}

model ContentModerationFlag {
  id               String                  @id @default(cuid())
  orgId            String
  kind             ContentModerationKind
  fileAssetId      String?
  targetId         String?
  status           ContentModerationStatus @default(PENDING)
  reporterUserId   String?
  reason           String?
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime                @default(now())

  @@index([orgId, status, createdAt])
  @@index([kind, status])
  @@index([fileAssetId])
  @@index([targetId])
}

model MemberProfile {
  id                      String    @id @default(cuid())
  orgId                   String
  userId                  String
  profilePhotoUrl         String?
  profilePhotoConsentAt   DateTime?
  marketingOptIn          Boolean   @default(true)
  publicVisibility        Boolean   @default(false)
  joinedViaReferralCodeId String?
  emergencyContact        Json?
  notes                   String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([orgId, createdAt])
  @@index([userId])
}

model GuardianConsent {
  id                String                          @id @default(cuid())
  minorUserId       String
  guardianName      String
  guardianEmail     String
  guardianPhone     String
  relationship      String
  status            ConsentStatus                   @default(PENDING)
  otpChallengeId    String?
  activeChallengeId String?
  challengeStatus   GuardianConsentChallengeStatus?
  challengedAt      DateTime?
  verifiedAt        DateTime?
  consentedAt       DateTime?
  metadata          Json?
  createdAt         DateTime                        @default(now())
  updatedAt         DateTime                        @updatedAt

  @@index([minorUserId])
  @@index([guardianEmail])
}

model GuardianConsentChallenge {
  id                 String                          @id @default(cuid())
  guardianConsentId  String
  minorUserId        String
  otpChallengeId     String?
  channel            GuardianConsentChallengeChannel @default(EMAIL_OTP)
  status             GuardianConsentChallengeStatus  @default(PENDING)
  challengeTokenHash String?
  attempts           Int                             @default(0)
  maxAttempts        Int                             @default(3)
  lastSentAt         DateTime?
  verifiedAt         DateTime?
  expiresAt          DateTime
  ipAddress          String?
  userAgent          String?
  failureReason      String?
  metadata           Json?
  createdAt          DateTime                        @default(now())
  updatedAt          DateTime                        @updatedAt

  @@index([guardianConsentId, status])
  @@index([minorUserId, status])
}

model ConsentRecord {
  id           String        @id @default(cuid())
  orgId        String?
  userId       String
  type         ConsentType
  status       ConsentStatus
  metadata     Json?
  recordedById String?
  createdAt    DateTime      @default(now())

  @@index([orgId])
  @@index([userId, type])
}

model DataExportRequest {
  id            String    @id @default(cuid())
  orgId         String?
  userId        String
  status        String    @default("requested")
  requestId     String?
  latestJobId   String?
  exportFormat  String    @default("json")
  exportUrl     String?
  notes         String?
  processedById String?
  processedAt   DateTime?
  completedAt   DateTime?
  failureReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, status])
  @@index([orgId, status])
}

model DataExportJob {
  id              String              @id @default(cuid())
  requestId       String
  orgId           String?
  userId          String
  status          DataExportJobStatus @default(QUEUED)
  format          DataExportFormat    @default(JSON)
  storageProvider String?             @default("local")
  fileAssetId     String?
  exportUrl       String?
  checksum        String?
  recordCount     Int?
  requestedById   String?
  processedById   String?
  startedAt       DateTime?
  completedAt     DateTime?
  expiresAt       DateTime?
  errorCode       String?
  errorMessage    String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([requestId, status])
  @@index([userId, status, createdAt])
  @@index([orgId, status, createdAt])
}

model AccountDeletionRequest {
  id            String    @id @default(cuid())
  orgId         String?
  userId        String
  status        String    @default("requested")
  requestId     String?
  latestJobId   String?
  notes         String?
  processedById String?
  processedAt   DateTime?
  scheduledFor  DateTime?
  completedAt   DateTime?
  failureReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, status])
  @@index([orgId, status])
}

model AccountDeletionJob {
  id             String                   @id @default(cuid())
  requestId      String
