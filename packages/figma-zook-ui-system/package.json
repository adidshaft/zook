{
  "name": "@zook/figma-ui-system",
  "version": "0.1.0",
  "private": true,
  "description": "Figma plugin that generates the Zook Product UI System v1 design file.",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --format=iife --target=es2017 --outfile=dist/main.js",
    "build:smoke": "esbuild src/smoke.ts --bundle --format=iife --target=es2017 --outfile=dist/smoke.js",
    "build:all": "pnpm build && pnpm build:smoke",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.117.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.3"
  }
}
