{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_ENV_PROFILE": "local",
        "EXPO_PUBLIC_API_MODE": "backend"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_ENV_PROFILE": "staging",
        "EXPO_PUBLIC_API_MODE": "backend"
      }
    },
    "production": {
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_ENV_PROFILE": "production",
        "EXPO_PUBLIC_API_MODE": "backend"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
