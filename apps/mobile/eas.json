{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "environment": "development",
      "env": {
        "ENV_PROFILE": "local",
        "EXPO_PUBLIC_ENV_PROFILE": "local"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "environment": "preview",
      "env": {
        "ENV_PROFILE": "staging",
        "EXPO_PUBLIC_ENV_PROFILE": "staging"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "environment": "production",
      "env": {
        "ENV_PROFILE": "production",
        "EXPO_PUBLIC_ENV_PROFILE": "production"
      }
    }
  }
}
