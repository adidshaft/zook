{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_ENV_PROFILE": "local",
        "EXPO_PUBLIC_API_MODE": "backend"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_ENV_PROFILE": "staging",
        "EXPO_PUBLIC_API_MODE": "backend"
      }
    },
    "device-preview": {
      "distribution": "internal",
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_ENV_PROFILE": "production",
        "EXPO_PUBLIC_API_MODE": "backend",
        "EXPO_PUBLIC_INCLUDE_DEMO": "false",
        "MOBILE_APP_NAME": "Zook Preview",
        "MOBILE_APP_SCHEME": "zook-preview",
        "MOBILE_IOS_BUNDLE_IDENTIFIER": "com.zook.app.preview",
        "MOBILE_ANDROID_PACKAGE": "com.zook.app.preview"
      }
    },
    "production": {
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_ENV_PROFILE": "production",
        "EXPO_PUBLIC_API_MODE": "backend",
        "EXPO_PUBLIC_INCLUDE_DEMO": "false"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6767848585"
      }
    }
  }
}
