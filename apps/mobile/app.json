{
  "expo": {
    "name": "Zook",
    "slug": "zook",
    "scheme": "zook",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.zook.mobile"
    },
    "android": {
      "package": "app.zook.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#070908"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Zook uses the camera to scan gym attendance QR codes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
